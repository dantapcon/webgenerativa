# Clave API de Google Maps (requerida para geocodificación y mapas)
# Obtener en: https://console.cloud.google.com/
# Activar APIs: Maps JavaScript API, Geocoding API, Places API
# IMPORTANTE: El mapa no funcionará sin esta configuración
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu_clave_api_aqui

# Configuración de Supabase (ya existentes)
NEXT_PUBLIC_SUPABASE_URL=tu_url_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_supabase
SUPABASE_SERVICE_ROLE_KEY=tu_clave_servicio_supabase
